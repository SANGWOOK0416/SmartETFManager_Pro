# --- Dependencies (라이브러리) ---
# 프론트엔드 및 백엔드 의존성 폴더 제외
node_modules/
backend/node_modules/

# --- Security (보안: 중요 정보 숨김) ---
# API 키, DB 비밀번호 등이 담긴 환경 변수 파일 제외
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env

# --- Build & Production (빌드 결과물) ---
# 배포용으로 생성된 파일 제외
build/
dist/

# --- Logs & Debug (로그 파일) ---
# 개발 중 발생하는 로그 파일 제외
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- OS Specific (운영체제 임시 파일) ---
# Mac 및 Windows에서 생성되는 시스템 파일 제외
.DS_Store
Thumbs.db

# --- IDE Specific (에디터 설정) ---
# VS Code 및 기타 에디터 개인 설정 제외
.vscode/
.idea/